# ============================================
# 环境变量配置模板
# ============================================
# 复制此文件为 .env 并填入真实的配置值
# 注意：.env 文件不会被提交到 Git

# ============================================
# AI 模型配置
# ============================================
# 阿里云 DashScope API Key
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# ============================================
# 搜索 API 配置
# ============================================
# 搜索 API Key
SEARCH_API_KEY=your_search_api_key_here

# Tavily 搜索 API Key
TAVILY_SEARCH_API_KEY=your_tavily_api_key_here

# ============================================
# GitHub 配置（用于 RAG）
# ============================================
GITHUB_TOKEN=your_github_token_here

# ============================================
# 百度翻译配置
# ============================================
BAIDU_TRANSLATE_APP_ID=your_baidu_app_id_here
BAIDU_TRANSLATE_APP_KEY=your_baidu_app_key_here

# ============================================
# QQ 邮箱配置
# ============================================
QQ_EMAIL_FROM=your_qq_email@qq.com
QQ_EMAIL_AUTH_CODE=your_qq_email_auth_code_here
QQ_EMAIL_SMTP_HOST=smtp.qq.com
QQ_EMAIL_SMTP_PORT=587

# ============================================
# PostgreSQL 配置
# ============================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password_here
POSTGRES_DB=super_ai_agent
POSTGRES_PORT=5432

# PGVector 配置
PGVECTOR_USERNAME=postgres
PGVECTOR_PASSWORD=your_pgvector_password_here

# ============================================
# MySQL 配置（如果使用）
# ============================================
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=super_ai_agent
MYSQL_USERNAME=root
MYSQL_PASSWORD=your_mysql_password_here
